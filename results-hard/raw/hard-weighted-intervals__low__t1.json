  "response": "```javascript\nfunction weightedIntervalMax(intervals) {\n  const items = intervals.slice().sort((a, b) => a[1] - b[1]);\n  const n = items.length;\n  const dp = new Array(n + 1).fill(0);\n  for (let i = 1; i <= n; i++) {\n    const [s, , v] = items[i - 1];\n    // find last j (1-indexed) with items[j-1].end <= s, via binary search\n    let lo = 0, hi = i - 1;\n    while (lo < hi) {\n      const mid = (lo + hi + 1) >> 1;\n      if (items[mid - 1][1] <= s) lo = mid;\n      else hi = mid - 1;\n    }\n    dp[i] = Math.max(dp[i - 1], dp[lo] + v);\n  }\n  return dp[n];\n}\n```",
